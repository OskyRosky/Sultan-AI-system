# Sultan Data Platform local environment example
# Copy to .env locally when ready. Do not commit real secrets.

# Project paths
SULTAN_PROJECT_ROOT=/Users/sultan/Trading/Sultan-AI-system
SULTAN_DATA_PLATFORM_DIR=/Users/sultan/Trading/Sultan-AI-system/02 Data Platform
SULTAN_DATA_DIR=/Users/sultan/Trading/Sultan-AI-system/data
SULTAN_RAW_DATA_DIR=/Users/sultan/Trading/Sultan-AI-system/data/raw
SULTAN_CURATED_DATA_DIR=/Users/sultan/Trading/Sultan-AI-system/data/curated
SULTAN_FEATURES_DATA_DIR=/Users/sultan/Trading/Sultan-AI-system/data/features
SULTAN_PIPELINE_LOG_DIR=/Users/sultan/Trading/Sultan-AI-system/02 Data Platform/logs/pipeline_runs

# PostgreSQL connection
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sultan_ai
POSTGRES_USER=sultan_user
POSTGRES_PASSWORD=replace_me
POSTGRES_SSLMODE=prefer

# Data platform defaults
SULTAN_DEFAULT_EXCHANGE=binance
SULTAN_DEFAULT_SYMBOLS=BTCUSDT,ETHUSDT
SULTAN_DEFAULT_TIMEFRAMES=1d,4h
SULTAN_OHLCV_MODE=incremental
SULTAN_OHLCV_FETCH_LIMIT=500
SULTAN_OHLCV_PAGE_LIMIT=1000
SULTAN_BTCUSDT_START_DATE=2017-01-01T00:00:00Z
SULTAN_ETHUSDT_START_DATE=2017-01-01T00:00:00Z
